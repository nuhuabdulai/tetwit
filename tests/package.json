{
  "name": "tetwit-test-framework",
  "version": "1.0.0",
  "description": "Comprehensive automated testing framework for TeTWIT application",
  "main": "tests/runner.js",
  "scripts": {
    "test": "node tests/runner.js",
    "test:admin": "node tests/runner.js --page=admin",
    "test:dashboard": "node tests/runner.js --page=dashboard",
    "test:auth": "node tests/runner.js --page=auth",
    "test:all": "node tests/runner.js --all",
    "test:ci": "node tests/runner.js --ci",
    "report": "node tests/generate-report.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chalk": "^4.1.2",
    "nodemailer": "^6.9.7",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jsonschema": "^1.4.1"
  },
  "keywords": ["testing", "automation", "ui-tests", "api-tests"],
  "author": "TeTWIT Team",
  "license": "MIT"
}
